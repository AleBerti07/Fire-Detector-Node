    { "id":"n_weather_tick","type":"inject","z":"flow_main","name":"Every 10 min",
      "repeat":"600","once":true,"onceDelay":"3","payload":"","payloadType":"date",
      "x":100,"y":480,"wires":[["n_weather_req"]] },

    { "id":"n_weather_req","type":"http request","z":"flow_main","name":"OpenWeatherMap",
      "method":"GET","ret":"obj",
      "url":"https://api.openweathermap.org/data/2.5/weather?lat=51.9849&lon=5.9539&units=metric&appid=YOUR_API_KEY_HERE",
      "x":300,"y":480,"wires":[["n_weather_parse"]] },

    { "id":"n_weather_parse","type":"function","z":"flow_main","name":"FWI",
      "func":"const d=msg.payload;\nif(!d||!d.main){node.warn('Weather error');return;}\nconst temp=d.main.temp,hum=d.main.humidity,wind=Math.round((d.wind.speed||0)*3.6);\nconst fwi=Math.round(Math.min(Math.max((temp-20)/20,0),1)*33+Math.min(Math.max((60-hum)/60,0),1)*33+Math.min(wind/60,1)*34);\nconst risk=fwi>=70?'EXTREME':fwi>=50?'HIGH':fwi>=30?'MODERATE':'LOW';\nconst key={EXTREME:'alarm',HIGH:'warning',MODERATE:'watch',LOW:'safe'}[risk];\nmsg.payload={temp,hum,wind,cond:d.weather[0].description,fwi,risk,key};\nreturn msg;",
      "outputs":1,"x":480,"y":480,"wires":[["n_ui_weather"]] },

    { "id":"n_ui_weather","type":"ui-template","z":"flow_main","group":"grp_weather",
      "name":"Weather","order":1,"width":"12","height":"2","templateScope":"local",
      "format":"<template>\n<div :style=\"{ display:'flex',alignItems:'center',gap:'16px',padding:'11px 16px',borderRadius:'8px',border:'1.5px solid '+borderClr,background:bgClr,fontFamily:'system-ui' }\">\n  <div style=\"display:flex;flex-direction:column;align-items:center;min-width:100px;gap:3px;\">\n    <div style=\"font-size:0.62em;letter-spacing:1px;color:#94a3b8;font-weight:600;\">FIRE WEATHER</div>\n    <div :style=\"{ background:badgeClr, color:'white', padding:'3px 12px', borderRadius:'20px', fontWeight:800, fontSize:'0.82em', letterSpacing:'1px' }\">{{ msg.payload.risk }}</div>\n    <div :style=\"{ color:badgeClr, fontWeight:800, fontSize:'1.1em' }\">{{ msg.payload.fwi }}/100</div>\n  </div>\n  <div style=\"width:1px;background:#e2e8f0;height:38px;\"></div>\n  <div style=\"display:flex;gap:22px;flex:1;flex-wrap:wrap;align-items:center;\">\n    <div style=\"display:flex;flex-direction:column;align-items:center;\">\n      <span style=\"font-size:1em;font-weight:700;color:#ef4444;\">{{ msg.payload.temp }}°C</span>\n      <span style=\"font-size:0.6em;letter-spacing:1px;color:#94a3b8;\">AMBIENT</span>\n    </div>\n    <div style=\"display:flex;flex-direction:column;align-items:center;\">\n      <span style=\"font-size:1em;font-weight:700;color:#3b82f6;\">{{ msg.payload.hum }}%</span>\n      <span style=\"font-size:0.6em;letter-spacing:1px;color:#94a3b8;\">HUMIDITY</span>\n    </div>\n    <div style=\"display:flex;flex-direction:column;align-items:center;\">\n      <span style=\"font-size:1em;font-weight:700;color:#06b6d4;\">{{ msg.payload.wind }} km/h</span>\n      <span style=\"font-size:0.6em;letter-spacing:1px;color:#94a3b8;\">WIND</span>\n    </div>\n    <div style=\"display:flex;flex-direction:column;align-items:center;\">\n      <span style=\"font-size:0.9em;font-weight:500;color:#475569;\">{{ msg.payload.cond }}</span>\n      <span style=\"font-size:0.6em;letter-spacing:1px;color:#94a3b8;\">CONDITIONS</span>\n    </div>\n  </div>\n  <div style=\"font-size:0.62em;color:#cbd5e1;margin-left:auto;\">OpenWeatherMap</div>\n</div>\n</template>\n<script>\nexport default {\n  computed: {\n    badgeClr(){ const c={safe:'#16a34a',watch:'#ca8a04',warning:'#ea580c',alarm:'#dc2626'}; return c[this.msg&&this.msg.payload&&this.msg.payload.key]||'#64748b'; },\n    borderClr(){ const c={safe:'#86efac',watch:'#fde047',warning:'#fdba74',alarm:'#fca5a5'}; return c[this.msg&&this.msg.payload&&this.msg.payload.key]||'#e2e8f0'; },\n    bgClr(){ const c={safe:'#f0fdf4',watch:'#fefce8',warning:'#fff7ed',alarm:'#fef2f2'}; return c[this.msg&&this.msg.payload&&this.msg.payload.key]||'#ffffff'; }\n  }\n}\n</script>",
      "storeOutMessages":false,"fwdInMessages":false,"resendOnRefresh":true,
      "x":680,"y":480,"wires":[[]] }
]
